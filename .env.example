# Copy to .env and fill in on hackathon day.
#
# IMPORTANT: for real Managed Agents (client.agents/interactions), run
# agentgrid from a Python >= 3.10 venv, e.g.:
#   python3.10 -m venv .venv && source .venv/bin/activate
#   pip install google-genai
# On Python 3.9, `pip install google-genai` silently installs 1.47.0 (the
# last 3.9-compatible release) instead of the real 2.x line, and the
# managed/auto backends will just quietly fall back to plain Gemini
# function-calling with no error. Plain `--backend gemini` works fine on
# Python >= 3.9, no venv required.

# --- Tier 1: real agents -------------------------------------
GEMINI_API_KEY=

# Model id (per Gemini 3.5 docs). Verify day-of with: python3 -m agentgrid doctor
AGENTGRID_MODEL=gemini-3.5-flash

# Managed Agents base agent (per Managed Agents quickstart).
AGENTGRID_BASE_AGENT=antigravity-preview-05-2026

# Backend: auto | mock | gemini | managed
#   auto    -> managed+gemini hybrid if key present, else mock
#   mock    -> deterministic offline backend (no key needed)
#   gemini  -> Gemini function-calling for every role
#   managed -> Managed Agents for reasoning roles + Gemini function-calling
#              for roles that must edit local files (needs Python >= 3.10 +
#              google-genai >= 2.0 — see note above; falls back to gemini
#              function-calling for every role if that surface is missing)
AGENTGRID_BACKEND=auto

# --- Optional ------------------------------------------------
# Real PRs: "owner/repo" that `gh` is authenticated for.
GITHUB_REPO=

# Computer Use interactive Verifier (visual mode / ISSUE-3 only). Active
# by default whenever a live backend + key are present; adds ~2 extra
# API round-trips and a headless Chromium launch per verify round
# (measured: +6.6s vs the static-screenshot path). Set to 1/true to skip
# it and always use the faster static-screenshot Verifier instead — e.g.
# for a time-boxed demo run. Every other mode (ISSUE-1/2/4) is unaffected
# either way.
AGENTGRID_CU_DISABLE=

# Set to 1/true to watch Computer Use drive a REAL, visible (non-headless,
# slowed down) Chromium window instead of running invisibly in the
# background. Purely for you to watch it work — leave unset for a fast,
# headless judged run.
AGENTGRID_CU_HEADED=

# Seconds of artificial pause per mock LLM turn (demo pacing). smoke forces 0.
AGENTGRID_MOCK_DELAY=0.0

# Dashboard port
AGENTGRID_PORT=8765
